{
  "_meta": {
    "version": "1.0.0",
    "stand": "2024-12",
    "quelle": "Heilmittel-Richtlinie G-BA, GKV-Spitzenverband Anlage 3a, Stand 01.12.2024"
  },

  "pflichtfelder": {
    "patientendaten": [
      { "feld": "krankenkasse",        "label": "Krankenkasse / Kostenträger",  "typ": "text" },
      { "feld": "patient_name",        "label": "Name des Versicherten",        "typ": "text" },
      { "feld": "patient_vorname",     "label": "Vorname des Versicherten",     "typ": "text" },
      { "feld": "patient_adresse",     "label": "Adresse des Versicherten",     "typ": "text" },
      { "feld": "patient_geburtsdatum","label": "Geburtsdatum",                 "typ": "datum" },
      { "feld": "versichertennummer",  "label": "Versichertennummer",           "typ": "text" },
      { "feld": "kostentraegerkennung","label": "Kostenträgerkennung (9-stellig)","typ": "numerisch_9" },
      { "feld": "status",              "label": "Versichertenstatus",           "typ": "text" }
    ],
    "arztdaten": [
      { "feld": "bsnr",         "label": "Betriebsstättennummer (BSNR)", "typ": "numerisch_9" },
      { "feld": "lanr",         "label": "Arztnummer (LANR)",            "typ": "numerisch_9" },
      { "feld": "arzt_name",    "label": "Name des Arztes (Stempel)",    "typ": "text" },
      { "feld": "arzt_beruf",   "label": "Berufsbezeichnung (Stempel)",  "typ": "text" },
      { "feld": "arzt_strasse", "label": "Straße (Stempel)",             "typ": "text" },
      { "feld": "arzt_plz_ort", "label": "PLZ + Ort (Stempel)",         "typ": "text" },
      { "feld": "arzt_telefon", "label": "Telefon (Stempel)",            "typ": "text" },
      { "feld": "unterschrift", "label": "Unterschrift des Arztes",      "typ": "vorhanden" },
      { "feld": "ausstellungsdatum", "label": "Ausstellungsdatum",       "typ": "datum" }
    ],
    "verordnung": [
      { "feld": "fachbereich",       "label": "Fachbereich (Physio/Ergo)", "typ": "auswahl", "optionen": ["Physiotherapie","Ergotherapie"] },
      { "feld": "icd10",             "label": "ICD-10-Code",               "typ": "icd10" },
      { "feld": "diagnosegruppe",    "label": "Diagnosegruppe",            "typ": "diagnosegruppe" },
      { "feld": "leitsymptomatik",   "label": "Leitsymptomatik",           "typ": "leitsymptomatik" },
      { "feld": "heilmittel",        "label": "Heilmittel (min. 1 vorrangig)", "typ": "heilmittel" },
      { "feld": "anzahl_einheiten",  "label": "Anzahl Behandlungseinheiten", "typ": "integer_positiv" },
      { "feld": "frequenz",          "label": "Behandlungsfrequenz",       "typ": "text" },
      { "feld": "hausbesuch",        "label": "Hausbesuch (ja/nein)",      "typ": "boolean" },
      { "feld": "zuzahlung",         "label": "Zuzahlungsstatus",          "typ": "auswahl", "optionen": ["zuzahlungspflichtig","zuzahlungsfrei"] }
    ]
  },

  "diagnosegruppen": {
    "physiotherapie": {
      "EX":  { "label": "Extremitäten und Becken",       "hoechstmenge": 6,  "blanko_moeglich": true },
      "WS":  { "label": "Wirbelsäule",                   "hoechstmenge": 6,  "blanko_moeglich": false },
      "CS":  { "label": "Hals-Schulter",                 "hoechstmenge": 6,  "blanko_moeglich": false },
      "ZN":  { "label": "Zentrales Nervensystem",        "hoechstmenge": 10, "blanko_moeglich": false },
      "PN":  { "label": "Peripheres Nervensystem",       "hoechstmenge": 10, "blanko_moeglich": false },
      "AT":  { "label": "Atemtherapie",                  "hoechstmenge": 6,  "blanko_moeglich": false },
      "GE":  { "label": "Geburtsvorbereitung",           "hoechstmenge": 14, "blanko_moeglich": false },
      "LY":  { "label": "Lymphdrainage",                 "hoechstmenge": 6,  "blanko_moeglich": false },
      "SO1": { "label": "Sonstige 1",                    "hoechstmenge": 6,  "blanko_moeglich": false },
      "SO2": { "label": "Sonstige 2",                    "hoechstmenge": 6,  "blanko_moeglich": false },
      "SO3": { "label": "Sonstige 3",                    "hoechstmenge": 6,  "blanko_moeglich": false },
      "SO4": { "label": "Sonstige 4",                    "hoechstmenge": 6,  "blanko_moeglich": false },
      "SO5": { "label": "Sonstige 5",                    "hoechstmenge": 10, "blanko_moeglich": false }
    },
    "ergotherapie": {
      "EN1": { "label": "Neurologisch 1",                "hoechstmenge": 10, "blanko_moeglich": false },
      "EN2": { "label": "Neurologisch 2",                "hoechstmenge": 10, "blanko_moeglich": false },
      "EN3": { "label": "Neurologisch 3",                "hoechstmenge": 10, "blanko_moeglich": true },
      "PS1": { "label": "Psychisch 1",                   "hoechstmenge": 10, "blanko_moeglich": false },
      "PS2": { "label": "Psychisch 2",                   "hoechstmenge": 10, "blanko_moeglich": false },
      "PS3": { "label": "Psychisch 3",                   "hoechstmenge": 10, "blanko_moeglich": true },
      "PS4": { "label": "Psychisch 4",                   "hoechstmenge": 10, "blanko_moeglich": true },
      "SB1": { "label": "Somatisch/Bewegungsapparat",    "hoechstmenge": 10, "blanko_moeglich": true }
    }
  },

  "stempel_pflichtfelder": [
    "arzt_name",
    "arzt_beruf",
    "arzt_strasse",
    "arzt_plz_ort",
    "arzt_telefon",
    "bsnr"
  ],

  "blanko_regeln": {
    "erkennungsmerkmal": "BLANKOVERORDNUNG",
    "felder_die_leer_bleiben_duerfen": ["heilmittel", "anzahl_einheiten", "frequenz"],
    "physio_erlaubte_gruppen": ["EX"],
    "ergo_erlaubte_gruppen": ["EN3", "PS3", "PS4", "SB1"]
  },

  "warnungen": {
    "hoechstmenge_ueberschritten_bvb": "Höchstmenge überschritten – nur zulässig bei langfristigem Heilmittelbedarf (LHB) oder besonderem Verordnungsbedarf (BVB). Rücksprache mit Arzt prüfen.",
    "blanko_falsche_gruppe": "Blankoverordnung nur für Diagnosegruppe EX (Physio) oder EN3/PS3/PS4/SB1 (Ergo) zulässig."
  }
}
